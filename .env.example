# Field Connect Environment Variables
# Copy this file to .env.local and fill in the values

# Supabase — get these from Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://iefwhxxhrycaalhxkfgp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-field-connect-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-field-connect-service-role-secret-key

# Google Maps — for reverse geocoding (GPS → address)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Gemini — for AI features (analytics insights)
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# Cron — required for scheduled auto punch-out route
CRON_SECRET=your-random-cron-secret
